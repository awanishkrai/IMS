// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
model user{
  id Int @id @default(autoincrement())
  name String
  email String
  password String
  role String

}
model seller{
  id Int @id @defult(autoincrement())
  sellerId Int
  seller User @relation(fields[sellerId]:reference:[id]);
}
model buyer{
  id Int  @id @default(autoincrement())
  buyerId Int
  seller User @relation(fields[buyerId]:reference:[id]);
}
